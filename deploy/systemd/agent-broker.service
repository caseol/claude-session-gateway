[Unit]
Description=agent-broker — A2A message broker for Claude Code agents (port 3470)
After=network.target session-gateway.service
Wants=session-gateway.service

[Service]
Type=simple
WorkingDirectory=%h/.local/share/agent-broker
ExecStart=/usr/bin/python3 %h/.local/share/agent-broker/broker.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
